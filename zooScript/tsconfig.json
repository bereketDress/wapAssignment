{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "es2020",
    "types": ["node"],

    "sourceMap": true,
    "declaration": false,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,
    "skipLibCheck": true
  }
}